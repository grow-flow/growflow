generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Strain {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  type         String         @default("photoperiod") // autoflower | photoperiod
  plants       Plant[]
  phasePresets PhasePreset[]
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  @@map("strains")
}

model Plant {
  id         Int          @id @default(autoincrement())
  name       String
  strainId   Int?
  strain     Strain?      @relation(fields: [strainId], references: [id])
  sourceType String       @default("seed") // seed | clone
  notes      String?      @default("")
  isActive   Boolean      @default(true)
  phases     PlantPhase[]
  events     PlantEvent[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("plants")
}

model PlantPhase {
  id          Int          @id @default(autoincrement())
  plantId     Int
  plant       Plant        @relation(fields: [plantId], references: [id], onDelete: Cascade)
  sortOrder   Int          @default(0)
  name        String
  durationMin Int          @default(7)
  durationMax Int          @default(14)
  startDate   DateTime?
  isActive    Boolean      @default(false)
  isCompleted Boolean      @default(false)
  notes       String?
  events      PlantEvent[]
  createdAt   DateTime     @default(now())

  @@map("plant_phases")
}

model PlantEvent {
  id        Int         @id @default(autoincrement())
  plantId   Int
  plant     Plant       @relation(fields: [plantId], references: [id], onDelete: Cascade)
  phaseId   Int?
  phase     PlantPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  type      String      // watering | observation | training | harvest | transplant
  title     String
  timestamp DateTime    @default(now())
  notes     String?
  data      String?     // JSON für type-spezifische Daten
  createdAt DateTime    @default(now())

  @@map("plant_events")
}

model PhasePreset {
  id          Int      @id @default(autoincrement())
  name        String
  sortOrder   Int      @default(0)
  growType    String   @default("photoperiod")
  sourceType  String   @default("seed")
  durationMin Int      @default(7)
  durationMax Int      @default(14)
  description String?
  strainId    Int?
  strain      Strain?  @relation(fields: [strainId], references: [id], onDelete: Cascade)

  @@unique([name, growType, sourceType, strainId])
  @@map("phase_presets")
}
